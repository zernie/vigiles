{
  "hooks": {
    "SessionStart": [
      {
        "command": "npm install && pip install ruff pylint && gem install rubocop 2>/dev/null"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "node validate.mjs CLAUDE.md"
      },
      {
        "matcher": "Edit|Write",
        "command": "npx prettier --check ."
      }
    ]
  }
}
